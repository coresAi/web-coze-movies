{
  "expo": {
    "name": "灯箱收藏",
    "slug": "lantern-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F0E0C",
    "splash": {
      "backgroundColor": "#0F0E0C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lantern.collection"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0E0C"
      },
      "package": "com.lantern.collection"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "lantern",
    "experiments": {
      "typedRoutes": true
    }
  }
}
